# ── LLM backend (need at least one) ──────────────────────────────────────────
OPENROUTER_API_KEY=your_key_here
ANTHROPIC_API_KEY=your_key_here

# Tiered client (cleaning/llm_client.py) — used by the cleaning pipeline,
# skill_planner, deep_escalation, and initialize_domain.py (Phase 2/3).
# Each tier defaults to LLM_BACKEND_DEFAULT if unset; LLM_BACKEND_DEFAULT
# itself defaults to "gpt-oss" (OpenRouter free tier) if nothing is set here.
# Valid tokens: gpt-oss | haiku-or | anthropic-haiku | anthropic-sonnet | anthropic-opus
#              | bedrock-haiku | bedrock-sonnet | bedrock-opus
LLM_BACKEND_DEFAULT=anthropic-haiku
#LLM_BACKEND_FAST=anthropic-haiku
#LLM_BACKEND_STANDARD=anthropic-haiku
LLM_BACKEND_DEEP=anthropic-sonnet

# Bedrock backends (bedrock-haiku/-sonnet/-opus) auth via the standard AWS
# credential chain (env vars, ~/.aws/credentials, or an instance role) — no
# API key needed. Model IDs are account/region-specific, so set the one(s)
# you'll use:
#AWS_REGION=us-east-1
#AWS_PROFILE=default
#BEDROCK_HAIKU_MODEL_ID=anthropic.claude-haiku-4-5-v1:0
#BEDROCK_SONNET_MODEL_ID=anthropic.claude-sonnet-4-5-v1:0
#BEDROCK_OPUS_MODEL_ID=anthropic.claude-opus-4-5-v1:0

# Legacy single-client factory (llm_client_factory.py) — used only by
# cli.py and scripts/research_domain.py (the pre-schema-aware CLI).
# Independent of the tiers above.
#LLM_BACKEND=openrouter
#OPENROUTER_MODEL=anthropic/claude-haiku-4-5
#ANTHROPIC_MODEL=claude-haiku-4-5-20251001
#ANTHROPIC_BUDGET_TOKENS=100000

# ── Web search enrichment ─────────────────────────────────────────────────────
TAVILY_API_KEY=your_key_here

# ── Database ──────────────────────────────────────────────────────────────────
DB_BACKEND=sqlite
DB_PATH=data/cleaning.db
#DB_BACKEND=postgres
#POSTGRES_DSN=postgresql://user:pass@localhost:5432/cleaning_db
